pipeline {
    agent any

    stages {

        stage('Clone Repository') {
            steps {
                git 'https://github.com/uttucs-pro/scientific-calculator.git'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('Test') {
            steps {
                sh 'mvn test'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t <dockerhub-username>/scientific-calculator .'
            }
        }

        stage('Push Docker Image') {
            steps {
                sh 'docker push <dockerhub-username>/scientific-calculator'
            }
        }
    }
}
